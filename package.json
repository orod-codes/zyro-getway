{
  "name": "z-getway",
  "version": "1.0.0",
  "description": "Zyro Gateway — real-time sync for mobile, web, and system clients",
  "license": "MIT",
  "author": "dorsis",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orod-codes/zyro-getway.git"
  },
  "homepage": "https://github.com/orod-codes/zyro-getway#readme",
  "bugs": {
    "url": "https://github.com/orod-codes/zyro-getway/issues"
  },
  "main": "dist/zyro.js",
  "module": "zyro/zyro.js",
  "browser": "dist/zyro.js",
  "exports": {
    ".": {
      "import": "./zyro/zyro.js",
      "require": "./dist/zyro.js",
      "default": "./dist/zyro.js"
    },
    "./server": {
      "require": "./src/index.js",
      "default": "./src/index.js"
    },
    "./config.example": "./zyro.config.example.js",
    "./package.json": "./package.json"
  },
  "files": [
    "assets",
    "bin",
    "dist",
    "src",
    "zyro",
    "scripts",
    "zyro.config.example.js",
    "server.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "node scripts/build-zyro.js",
    "config": "node scripts/init-config.js",
    "prestart": "npm run build",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "release": "npm version patch --no-git-tag-version && npm publish --access public"
  },
  "bin": {
    "z-getway": "bin/z-getway.js",
    "zyro-gateway": "bin/zyro-gateway.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "z-getway",
    "zyro",
    "zyro-gateway",
    "socket.io",
    "real-time",
    "payment-sync",
    "income-sync"
  ],
  "dependencies": {
    "express": "^4.21.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
