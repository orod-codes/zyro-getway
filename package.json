{
  "name": "z-getway",
  "version": "1.1.0",
  "description": "Zyro Gateway — real-time income sync, Express Checkout, and browser SDK",
  "license": "MIT",
  "author": "dorsis",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/orod-codes/zyro-getway.git"
  },
  "homepage": "https://github.com/orod-codes/zyro-getway#readme",
  "bugs": {
    "url": "https://github.com/orod-codes/zyro-getway/issues"
  },
  "main": "dist/zyro.js",
  "module": "zyro/zyro.js",
  "browser": "dist/zyro.js",
  "exports": {
    ".": {
      "import": "./zyro/zyro.js",
      "require": "./dist/zyro.js",
      "default": "./dist/zyro.js"
    },
    "./server": {
      "require": "./src/index.js",
      "default": "./src/index.js"
    },
    "./config.example": "./zyro.config.example.js",
    "./package.json": "./package.json"
  },
  "files": [
    "assets",
    "bin",
    "check-out/dist",
    "dist",
    "src",
    "zyro",
    "scripts",
    "zyro.config.example.js",
    "server.js",
    "README.md",
    "SETUP.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "node scripts/build-zyro.js",
    "build:checkout": "node scripts/build-checkout.js",
    "build:all": "npm run build && npm run build:checkout",
    "config": "node scripts/init-config.js",
    "demo:orders": "node scripts/demo-order-api.js",
    "prestart": "npm run build:all",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build:all",
    "release": "node scripts/publish-all.js"
  },
  "bin": {
    "z-getway": "bin/z-getway.js",
    "zyro-gateway": "bin/zyro-gateway.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "z-getway",
    "zyro",
    "zyro-gateway",
    "checkout",
    "payment-gateway",
    "socket.io",
    "real-time",
    "ethiopia",
    "telebirr",
    "income-sync"
  ],
  "dependencies": {
    "express": "^4.21.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
