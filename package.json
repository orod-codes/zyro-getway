{
  "name": "zyro",
  "version": "1.0.0",
  "description": "Zyro Gateway — real-time phone ↔ PC sync (terminal server + browser client)",
  "license": "MIT",
  "main": "dist/zyro.js",
  "module": "zyro/zyro.js",
  "browser": "dist/zyro.js",
  "exports": {
    ".": {
      "import": "./zyro/zyro.js",
      "require": "./dist/zyro.js",
      "default": "./dist/zyro.js"
    },
    "./server": "./server.js",
    "./config.example": "./zyro.config.example.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "zyro",
    "scripts",
    "zyro.config.example.js",
    "server.js",
    "README.md"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "node scripts/build-zyro.js",
    "config": "node scripts/init-config.js",
    "prestart": "npm run build",
    "prepare": "npm run build"
  },
  "bin": {
    "zyro-gateway": "server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "zyro",
    "zyro-gateway",
    "socket.io",
    "real-time",
    "ethiopia",
    "telebirr",
    "payment-sync"
  ],
  "dependencies": {
    "express": "^4.21.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
